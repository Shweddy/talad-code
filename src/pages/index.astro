---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Garland from '../components/Garland.astro';
import ProjectCard from '../components/ProjectCard.astro';

const issues = (await getCollection('issues', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.issue - a.data.issue
);
const latest = issues[0];
const totalProjects = issues.reduce((n, i) => n + i.data.projects.length, 0);

const thaiDate = latest.data.date.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
});
---

<Base title="ตลาดโค้ด — ตลาดสดโอเพนซอร์สของนักพัฒนาไทย">
  <header class="wrap hero">
    <div>
      <span class="issue-tag mono">
        <span class="dot"></span>
        ฉบับที่ {latest.data.issue} · {thaiDate}
      </span>
      <h1>
        ตลาดสดโอเพนซอร์ส<br />เปิดแผงใหม่ <span class="gold">ทุกเดือน</span>
      </h1>
      <p class="hero-sub">
        เดินตลาดหาของดีเข้าครัวโค้ดของคุณ — เราคัดโปรเจกต์โอเพนซอร์สน่าสนใจ
        มาจัดแผงพร้อมคำอธิบายภาษาไทยเข้าใจง่าย เหมาะทั้งมือใหม่ที่เพิ่งเริ่มเดิน
        และขาประจำที่อยากเจอของใหม่
      </p>
      <div class="hero-actions">
        <a class="btn btn-gold" href={`/issues/${latest.id}`}>เดินตลาดฉบับล่าสุด</a>
        <a
          class="btn btn-line"
          href="https://github.com/taladcode/content/issues/new/choose"
          rel="noopener">ส่งโปรเจกต์ของคุณ</a
        >
      </div>
      <p class="hero-stats mono">
        {issues.length} ฉบับ · {totalProjects} โปรเจกต์ที่แนะนำแล้ว
      </p>
    </div>
  </header>

  <Garland />

  <section class="wrap">
    <div class="eyebrow">แผงที่ {latest.data.issue} — ของเด็ดประจำเดือน</div>
    <h2>{latest.data.title}</h2>
    <p class="sec-sub">
      พ่อค้าแม่ค้าอาสาสมัครคัดของจากที่ชุมชนส่งเข้ามา
      พร้อมบอกว่าทำไมถึงน่าหยิบใส่ตะกร้า
    </p>
    <div class="grid">
      {latest.data.projects.map((p) => <ProjectCard {...p} />)}
    </div>
    <div class="more">
      <a class="btn btn-line" href="/issues">ดูแผงย้อนหลังทั้งหมด →</a>
    </div>
  </section>

  <section class="wrap">
    <div class="starter">
      <div>
        <h2 class="starter-h">เพิ่งเริ่มเดินตลาด?</h2>
        <p class="starter-p">
          มีคู่มือพาเดินทีละขั้น ตั้งแต่สมัคร GitHub จนถึงส่ง Pull Request
          แรกในชีวิต
        </p>
      </div>
      <a class="btn btn-gold" href="/start">มือใหม่เริ่มที่นี่</a>
    </div>
  </section>
</Base>

<style>
  .hero { padding-top: 96px; padding-bottom: 72px; max-width: 800px; }
  .issue-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--marigold);
    border: 1px solid rgba(246, 177, 45, 0.35);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 28px;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--leaf);
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  h1 {
    font-weight: 700;
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .gold { color: var(--marigold); }
  .hero-sub { font-size: 1.1rem; color: var(--cream-dim); max-width: 32em; margin-bottom: 36px; }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-stats { margin-top: 28px; font-size: 13px; color: var(--cream-dim); }

  section { padding-top: 72px; padding-bottom: 24px; }
  h2 { font-weight: 600; font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 12px; }
  .sec-sub { color: var(--cream-dim); max-width: 38em; margin-bottom: 44px; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .more { margin-top: 40px; text-align: center; }

  .starter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    background: var(--indigo);
    border: 1px solid var(--indigo-soft);
    border-radius: 12px;
    padding: 32px 36px;
  }
  .starter-h { font-size: 1.3rem; margin-bottom: 6px; }
  .starter-p { font-size: 15px; color: var(--cream-dim); max-width: 34em; }

  @media (max-width: 820px) {
    .hero { padding-top: 64px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
