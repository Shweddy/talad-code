---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Garland from '../../components/Garland.astro';
import ProjectCard from '../../components/ProjectCard.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues', ({ data }) => !data.draft);
  return issues.map((issue) => ({
    params: { id: issue.id },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content } = await render(issue);

const thaiDate = issue.data.date.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${issue.data.title} — ตลาดโค้ด`}>
  <section class="wrap">
    <div class="eyebrow">ตีพิมพ์ {thaiDate}</div>
    <h1>{issue.data.title}</h1>
    {
      issue.data.editors.length > 0 && (
        <p class="editors mono">
          บรรณาธิการฉบับนี้:{' '}
          {issue.data.editors.map((e, i) => (
            <>
              {i > 0 && ', '}
              <a href={`https://github.com/${e}`} rel="noopener">@{e}</a>
            </>
          ))}
        </p>
      )
    }
    <div class="prose"><Content /></div>
  </section>

  <Garland />

  <section class="wrap">
    <div class="grid">
      {issue.data.projects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>
</Base>

<style>
  section { padding-top: 64px; padding-bottom: 24px; }
  h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 12px; }
  .editors { font-size: 13px; color: var(--cream-dim); margin-bottom: 28px; }
  .editors a { color: var(--marigold-soft); }
  .prose { max-width: 44em; color: var(--cream); }
  .prose :global(p) { margin-bottom: 1em; }
  .prose :global(a) { color: var(--marigold); text-decoration: underline; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  @media (max-width: 820px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
